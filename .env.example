# -----------------------------
# X Account Ops 示例配置
# 复制为 .env 后再填写真实值
# -----------------------------

# OAuth 2.0
Client ID=your_x_oauth2_client_id
Client Secret=your_x_oauth2_client_secret
Access Token=your_x_oauth2_access_token
Refresh Token=your_x_oauth2_refresh_token
User ID=your_x_user_id

# OAuth 1.0a
# 如果你需要图文发帖，建议同时配置这四项
Consumer Key=your_x_oauth1_consumer_key
Consumer Key Secret=your_x_oauth1_consumer_secret
auth1 Access Token=your_x_oauth1_access_token
auth1 Access Secret=your_x_oauth1_access_secret

# 代理配置
# 很多地区无法直接访问 X API，建议按需配置代理
# 常见格式：
#   http://127.0.0.1:7890
#   socks5://127.0.0.1:1080
#
# 如果你只有一个统一代理，优先填写 HTTPS_PROXY
# 如果 HTTP/HTTPS 都走同一个代理，也可以两项都写
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# 可选：统一代理
# ALL_PROXY=socks5://127.0.0.1:1080
